# docker/.env.bench.example
#
# Copy to docker/.env.bench (or let the CI workflow generate it from
# GitHub secrets) before running benchmarks locally:
#   cp docker/.env.bench.example docker/.env.bench
#   bash benchmarks/_common/env_setup.sh
#
# In CI, LLM_API_KEY is injected from a GitHub Actions secret and the
# rest of the file is generated by benchmarks/_common/env_setup.sh.

# --- Required: LLM provider credentials ---
LLM_API_KEY=
LLM_BASE_URL=https://api.minimaxi.com/anthropic
LLM_MODEL=minimax/MiniMax-M2.7

# --- Optional: container / runtime overrides ---
# OPENCLAW_IMAGE=acautomata/openclaw-docker-cn-im:latest
# BENCH_RUN_ID=local-dev
# DOCKER_BIND=127.0.0.1
# OPENCLAW_GATEWAY_PORT=18789
